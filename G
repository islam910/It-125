import sqlite3

# Подключение к базе данных
conn = sqlite3.connect("employees.db")
cursor = conn.cursor()

# Создание таблицы
cursor.execute("""
CREATE TABLE IF NOT EXISTS employees (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    position TEXT,
    salary INTEGER
)
""")

conn.commit()


# Добавление сотрудника
def add_employee():
    name = input("Имя: ")
    position = input("Должность: ")
    salary = int(input("Зарплата: "))

    cursor.execute(
        "INSERT INTO employees (name, position, salary) VALUES (?, ?, ?)",
        (name, position, salary)
    )
    conn.commit()
    print("Сотрудник добавлен")


# Показать всех сотрудников
def show_employees():
    cursor.execute("SELECT * FROM employees")
    for row in cursor.fetchall():
        print(row)


# Поиск сотрудника
def search_employee():
    name = input("Введите имя для поиска: ")
    cursor.execute("SELECT * FROM employees WHERE name LIKE ?", ('%' + name + '%',))
    results = cursor.fetchall()

    for row in results:
        print(row)


# Сортировка сотрудников
def sort_employees():
    print("1 - по имени")
    print("2 - по зарплате")

    choice = input("Выберите вариант: ")

    if choice == "1":
        cursor.execute("SELECT * FROM employees ORDER BY name")
    elif choice == "2":
        cursor.execute("SELECT * FROM employees ORDER BY salary")

    for row in cursor.fetchall():
        print(row)


# Меню программы
while True:
    print("\n1 - Добавить сотрудника")
    print("2 - Показать сотрудников")
    print("3 - Поиск сотрудника")
    print("4 - Сортировка сотрудников")
    print("5 - Выход")

    choice = input("Выберите действие: ")

    if choice == "1":
        add_employee()
    elif choice == "2":
        show_employees()
    elif choice == "3":
        search_employee()
    elif choice == "4":
        sort_employees()
    elif choice == "5":
        break

conn.close()
